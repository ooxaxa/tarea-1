#ifndef EJERCICIO_H
#define EJERCICIO_H

#include <string>
using namespace std;

class Ejercicio {
protected:
    int intensidad;
    int tiempo;

public:
    Ejercicio(int intensidad, int tiempo);
    virtual int getIntensidad();
    virtual int getTiempo();
    virtual string getTipo() = 0;
    virtual ~Ejercicio();
};

#endif

#include "Ejercicio.h"

Ejercicio::Ejercicio(int intensidad, int tiempo) {
    this->intensidad = intensidad;
    this->tiempo = tiempo;
}

int Ejercicio::getIntensidad() {
    return intensidad;
}

int Ejercicio::getTiempo() {
    return tiempo;
}

Ejercicio::~Ejercicio() {}

